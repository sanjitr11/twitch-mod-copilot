# Server Configuration
PORT=3001

# Twitch Configuration (REQUIRED)
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_OAUTH_TOKEN=oauth:your_oauth_token_here
TWITCH_CHANNEL=channelname

# Twitch Moderation (OPTIONAL - for Phase 2)
# TWITCH_MOD_TOKEN=your_moderator_token
# TWITCH_BROADCASTER_ID=broadcaster_user_id

# Sampling Configuration
BASE_SAMPLING_RATE=0.10
RAID_SAMPLING_RATE=0.40
RAID_MSGS_PER_SEC=10

# Database
DATABASE_PATH=./data/moderation.db

# Dashboard
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
